{
  "expo": {
    "name": "IRIS Women’s Wellness App",
    "slug": "iris-womens-wellness-app",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "iris-wellness",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "se.mojjo.iris-wellness",
      "buildNumber": "2",
      "infoPlist": {
        "NSCameraUsageDescription": "IRIS uses your camera to perform on-device iris analysis for wellness tracking. Photos are processed locally and never uploaded.",
        "NSHealthShareUsageDescription": "IRIS reads heart rate variability, wrist temperature, and sleep data to enhance your wellness insights. This data stays on your device.",
        "NSHealthUpdateUsageDescription": "IRIS does not write data to Apple Health."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "se.mojjo.iris_wellness",
      "permissions": [
        "CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://iris-wellness.mojjo.se/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "IRIS uses your camera to perform on-device iris analysis for wellness tracking. Photos are processed locally and never uploaded.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#E89BA4"
        }
      ],
      "expo-splash-screen"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}