# Selectively include only the lib/ and types/ files the backend imports.
# Backend depends on @/lib/logger, @/lib/crypto, and @/types via tsconfig paths.
lib/*
!lib/logger.ts
!lib/crypto.ts
types/*
!types/index.ts

