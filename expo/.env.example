# ============================================
# Iris Women's Wellness App - Environment Variables
# ============================================
# Copy this file to .env and fill in the values.
#
#   cp .env.example .env

# ----- API Configuration -----
# Base URL for the backend API (tRPC / Hono server)
EXPO_PUBLIC_RORK_API_BASE_URL=https://your-api-domain.com

# ----- Supabase (Postgres backend) -----
# Required by the Hono backend for persistence.
# Get these from https://app.supabase.com/project/<your-project>/settings/api
SUPABASE_URL=https://your-project-ref.supabase.co
# ⚠️ service_role key bypasses RLS. NEVER put it in the mobile app bundle.
# Only set this on the deploy host (Fly.io / Vercel / Railway) and locally for dev.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# ----- Admin Authentication -----
# SHA-256 hashes of admin passwords.
# Generate with:  echo -n "your-password" | shasum -a 256 | awk '{print $1}'
ADMIN_HASH_SUPER=
ADMIN_HASH_ANALYST=
ADMIN_HASH_VIEWER=

# ----- CORS (optional) -----
# Allowed origin for the backend API. Defaults to '*' if unset.
CORS_ORIGIN=https://your-app-domain.com
